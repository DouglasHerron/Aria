# ============================================================
# ARIA — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# Or use the browser wizard at http://localhost:3000/setup (local dev).
# NEVER commit .env.local to git.
# ============================================================

# ---- NextAuth -----------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="replace_me"             # Generate: openssl rand -base64 32

# ---- Google OAuth -------------------------------------------
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Each clone/install uses its own Google Cloud project + OAuth client.
# Required scopes: Gmail API (read/send), Google Calendar API (read/write)
GOOGLE_CLIENT_ID=replace_me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_me

# ---- Supabase (NextAuth database backend) -------------------
# Create a project at supabase.com. Find these under:
# Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_me              # "anon / public" key — safe for future client use
SUPABASE_SERVICE_ROLE_KEY=replace_me      # "service_role" key — SECRET, server-side only, NEVER expose to client

# ---- AI Providers -------------------------------------------
# AI_PROVIDER controls which model is used at runtime.
# Set to 'claude', 'openai', or 'ollama'. Default: claude
AI_PROVIDER=claude

# AI_MODE controls whether ARIA auto-calls AI.
# off: no AI calls allowed
# on_demand: only call AI when explicitly requested in UI
# auto: widgets can auto-generate on load
AI_MODE=on_demand

# Anthropic (Claude)
# Get at: console.anthropic.com
ANTHROPIC_API_KEY=replace_me
ANTHROPIC_MODEL=claude-opus-4-6         # or claude-sonnet-4-6

# OpenAI
# Get at: platform.openai.com
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o

# Ollama (Local)
# Install: https://ollama.com
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# ---- Obsidian Bridge ----------------------------------------
# Absolute path to your Obsidian vault (macOS/Linux or Windows)
# macOS/Linux example: /Users/you/Documents/ObsidianVault
# Windows example: C:\Users\you\Documents\ObsidianVault
OBSIDIAN_VAULT_PATH=

# Obsidian Local REST API plugin (install from Community Plugins)
# Default port after install: 27123
OBSIDIAN_REST_API_PORT=27123
OBSIDIAN_REST_API_KEY=replace_me                  # Set in Obsidian plugin settings

# ---- Apple Calendar (CalDAV) --------------------------------
# V1 is read-only via CalDAV. Uses iCloud credentials.
# App-specific password required (NOT your main Apple ID password)
# Generate at: appleid.apple.com → Sign-In and Security → App-Specific Passwords
APPLE_CALDAV_USERNAME=                  # your Apple ID email
APPLE_CALDAV_PASSWORD=                  # app-specific password
APPLE_CALDAV_URL=https://caldav.icloud.com

# ---- Optional: AI prompt personalization --------------------
# ARIA_USER_NAME=Alex
# ARIA_USER_CONTEXT=Full-stack engineer; prefers concise bullet summaries.

# ---- Setup wizard (production self-host only) ---------------
# In production, POST /api/setup is disabled unless you set:
# SETUP_WIZARD_ENABLED=true

# ---- Feature Flags ------------------------------------------
# Set to 'true' to use mock data instead of real APIs (for demo recording)
DEMO_MODE=false
